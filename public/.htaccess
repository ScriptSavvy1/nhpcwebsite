# NHPC static site — Apache/cPanel config.
# Deploy at the domain root (public_html/). The rules below assume the site
# lives at nhpc.gov.so/ ; under a subfolder the absolute paths won't resolve.

DirectoryIndex index.html

RewriteEngine On
# Root → English homepage (Somali is at /so/).
RewriteRule ^$ /en/ [R=302,L]

# Custom 404 page (generated by the build at /404.html).
ErrorDocument 404 /404.html

# ── Gzip text assets ──────────────────────────────────────────────
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html
  AddOutputFilterByType DEFLATE text/css
  AddOutputFilterByType DEFLATE application/javascript
  AddOutputFilterByType DEFLATE application/json
  AddOutputFilterByType DEFLATE image/svg+xml
</IfModule>

# ── Long cache for static assets (30 days) ────────────────────────
<IfModule mod_headers.c>
  <FilesMatch "\.(woff2|png|jpg|jpeg|svg|pdf|ico)$">
    Header set Cache-Control "public, max-age=2592000"
  </FilesMatch>
</IfModule>
