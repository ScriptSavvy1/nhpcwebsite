# ── Resend (the ONLY place a complaint is stored: the inbox) ──────────
# Without these the API route refuses to accept complaints rather than
# accepting one it cannot deliver.
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
# Must be a domain verified in Resend.
COMPLAINTS_FROM="NHPC Complaints <complaints@nhpc.gov.so>"
COMPLAINTS_TO=info@nhpc.gov.so

# ── IP hashing ────────────────────────────────────────────────────────
# Raw IPs are never stored or logged. They are hashed with this salt for
# rate limiting only. Set to a long random string; changing it resets
# every in-flight rate-limit window.
IP_HASH_SALT=change-me-to-a-long-random-string

# ── Rate limiting — REQUIRED IN PRODUCTION ────────────────────────────
# The app THROWS ON COLD START in production if these are missing. This is
# deliberate: per-instance memory does not hold across serverless
# instances, so their absence means the public complaints form has no rate
# limit at all. A form that will not start is a fixable problem; a form
# with no rate limit is an incident.
# Not needed for local development (NODE_ENV=development).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
